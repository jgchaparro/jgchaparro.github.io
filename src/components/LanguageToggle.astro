---
// Language toggle — EN active, ES/EL wired but deferred (point to EN for now).
const locales = [
  { code: 'en', label: 'EN', href: '/en/', active: true },
  { code: 'es', label: 'ES', href: '/en/', active: false },
  { code: 'el', label: 'EL', href: '/en/', active: false },
];
---

<div class="inline-flex items-center gap-0 rounded-lg border border-slate-300 p-1 text-xs font-semibold dark:border-white/15 sm:gap-0.5 sm:p-0.5">
  {
    locales.map((locale) => (
      <a
        href={locale.href}
        aria-current={locale.active ? 'true' : undefined}
        title={locale.active ? `${locale.label} (current)` : `${locale.label} — coming soon`}
        class:list={[
          'rounded-md px-1.5 py-0.5 transition-colors sm:px-2 sm:py-1',
          locale.active
            ? 'bg-brand-700 text-white dark:bg-blue-500 dark:text-slate-950'
            : 'text-slate-500 hover:text-brand-700 dark:text-slate-400 dark:hover:text-blue-400',
        ]}
      >
        {locale.label}
      </a>
    ))
  }
</div>
