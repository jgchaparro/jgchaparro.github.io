---
const raw = Astro.url.pathname;
const lang = raw.startsWith('/es') ? 'es' : raw.startsWith('/el') ? 'el' : 'en';
const canonical = lang === 'en' ? raw : (raw.slice(lang.length + 1) || '/');

const localePath = (code: string) => {
  if (code === 'en') return canonical;
  return canonical === '/' ? `/${code}` : `/${code}${canonical}`;
};

const locales = [
  { code: 'en', label: 'EN', active: lang === 'en' },
  { code: 'es', label: 'ES', active: lang === 'es' },
  { code: 'el', label: 'EL', active: lang === 'el' },
];
---

<div class="inline-flex items-center gap-0 rounded-lg border border-slate-300 p-1 text-xs font-semibold dark:border-white/15 sm:gap-0.5 sm:p-0.5">
  {
    locales.map((locale) => (
      <a
        href={localePath(locale.code)}
        aria-current={locale.active ? 'true' : undefined}
        title={locale.label}
        class:list={[
          'rounded-md px-1.5 py-0.5 transition-colors sm:px-2 sm:py-1',
          locale.active
            ? 'bg-brand-700 text-white dark:bg-blue-500 dark:text-slate-950'
            : 'text-slate-500 hover:text-brand-700 dark:text-slate-400 dark:hover:text-blue-400',
        ]}
      >
        {locale.label}
      </a>
    ))
  }
</div>
