---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  category?: string;
  href?: string | null;
  logo?: string | null;
  image?: string | null;
  /** 'ready' renders full opacity; 'wip' dims the card and shows a badge. */
  status?: 'ready' | 'wip';
  visitText?: string;
}

const { title, description, category, href, logo, image, status = 'ready', visitText = 'Visit' } = Astro.props;

const isLink = Boolean(href);
const Tag = isLink ? 'a' : 'div';
const isWip = status === 'wip';
---

<Tag
  href={href ?? undefined}
  target={isLink ? '_blank' : undefined}
  rel={isLink ? 'noopener noreferrer' : undefined}
  class:list={[
    'group relative flex h-full flex-col overflow-hidden',
    isLink ? 'card-interactive' : 'card',
    isWip && 'opacity-70',
  ]}
>
  {
    image && (
      <img src={image} alt={title} class="h-40 w-full object-cover" />
    )
  }

  <div class="flex flex-1 flex-col p-6 pt-4 sm:pt-6">
    {
      logo && (
        <div class="mb-4 flex h-16 w-full items-center">
          <img src={logo} alt={`${title} logo`} class="h-full w-full object-contain" />
        </div>
      )
    }

  <div class="mb-3 flex items-center justify-between gap-2">
    {
      category && (
        <span class="inline-block rounded-full bg-brand-50 px-2.5 py-1 text-xs font-semibold text-brand-700 dark:bg-blue-500/10 dark:text-blue-400">
          {category}
        </span>
      )
    }
    {
      isWip && (
        <span class="inline-block rounded-full bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-500 dark:bg-white/5 dark:text-slate-400">
          In progress
        </span>
      )
    }
  </div>

  <h3 class="text-lg font-bold tracking-tight text-slate-900 dark:text-slate-50">
    {title}
  </h3>

  <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
    {description}
  </p>

  {
    isLink && (
      <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-700 transition-colors group-hover:gap-2 dark:text-blue-400">
        {visitText}
        <Icon name="heroicons:arrow-up-right-20-solid" class="h-4 w-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
      </span>
    )
  }
  </div>
</Tag>
