---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimelineItem from '../../components/TimelineItem.astro';
import { Icon } from 'astro-icon/components';

const experience = [
  {
    role: 'Senior AI Engineer',
    org: 'Devoteam (Google Cloud Partner)',
    period: 'Μαρ 2026 – Παρόν',
    location: 'Μαδρίτη',
    logo: '/images/logos/logo-devoteam.jpg',
    description:
      'Σχεδιασμός, υλοποίηση και βελτίωση εργαλείων ΤΝ για 3 πελάτες στους τομείς τηλεπικοινωνιών, ασφαλίσεων και φιλοξενίας, συμπεριλαμβανομένων αγεντικών συστημάτων (Langchain + ADK) και αγωγών δεδομένων (KubeFlow Pipelines, Dataform) στο οικοσύστημα Google Cloud Platform.',
  },
  {
    role: 'AI Development Engineer',
    org: 'Comunidad de Madrid',
    period: 'Νοε 2025 – Μαρ 2026',
    location: 'Μαδρίτη',
    logo: '/images/logos/logo-comunidad-madrid.jpg',
    description:
      'Σχεδιασμός και ενσωμάτωση εργαλείων ΤΝ (chatbots, RAG, συστήματα πρακτόρων) σε θεσμικές ιστοσελίδες και εσωτερικές διαδικασίες.',
  },
  {
    role: 'Global Data Scientist (Senior & Junior)',
    org: 'Havas Media Network',
    period: 'Σεπτ 2022 – Νοε 2025',
    location: 'Μαδρίτη',
    logo: '/images/logos/logo-havas.jpg',
    description:
      'Σχεδιασμός και υλοποίηση σε Python ψηφιακών προϊόντων για ενεργοποίηση κοινού με χρήση NLP. Ανανέωση προϊόντων με ενσωμάτωση LLMs, RAG και αγεντικών συστημάτων (LangGraph + LangSmith). Βιομηχανοποίηση σε Databricks, BigQuery και GCP. Μοντελοποίηση δομικών εξισώσεων (SEM).',
  },
  {
    role: 'Λέκτορας',
    org: 'Universidad Alfonso X el Sabio (UAX)',
    period: 'Ιαν 2025 – Ιουλ 2025',
    location: 'Μαδρίτη',
    logo: '/images/logos/logo-uax.jpg',
    description: 'Διδασκαλία Νευρωνικών Δικτύων και Τεχνητής Νοημοσύνης στο Πτυχίο Τεχνητής Νοημοσύνης.',
  },
];

const education = [
  {
    role: 'Μεταπτυχιακό στην Τεχνητή Νοημοσύνη',
    org: 'Universidad Alfonso X el Sabio (UAX)',
    period: 'Οκτ 2023 – Ιουλ 2024',
    logo: '/images/logos/logo-uax.jpg',
    thesis: {
      title: 'ΤΝ για τη διατήρηση γλωσσών σε κίνδυνο: στρατηγική για τη διατήρηση του τσακώνικου ελληνικού μέσω της ανδαλουσιανής ισπανικής',
    },
  },
  {
    role: 'Μεταπτυχιακό Εξειδίκευσης σε Deep Learning & Επιστήμη Δεδομένων',
    org: 'KSchool',
    period: 'Νοε 2022 – Μαΐ 2023',
    logo: '/images/logos/logo-kschool.jpg',
  },
  {
    role: 'Bootcamp Ανάλυσης Δεδομένων',
    org: 'Ironhack',
    period: 'Μαρ 2022 – Ιουν 2022',
    logo: '/images/logos/logo-ironhack.jpg',
  },
  {
    role: 'Πτυχίο Διεθνών Σχέσεων',
    org: 'Universidad Alfonso X el Sabio (UAX)',
    period: 'Σεπτ 2016 – Ιουν 2022',
    logo: '/images/logos/logo-uax.jpg',
    thesis: {
      title: 'Γεωοικονομική διάσταση της Πρωτοβουλίας του Δρόμου του Μεταξιού',
    },
    grade: {
      average: 9.17,
      honorsSubjects: 4,
    },
  },
  {
    role: 'Πτυχίο Διοίκησης Επιχειρήσεων',
    org: 'Universidad Alfonso X el Sabio (UAX)',
    period: 'Σεπτ 2018 – Ιουλ 2021',
    logo: '/images/logos/logo-uax.jpg',
    thesis: {
      title: 'Επίδραση της οικονομικής ελευθερίας στα δικαιώματα πολιτικής συμμετοχής και τις πολιτικές ελευθερίες',
    },
    grade: {
      average: 9.62,
      honorsSubjects: 12,
    },
    award: 'Υποψήφιος για το IV Βραβείο Διπλωματικής',
  },
];
---

<BaseLayout
  title="Καριέρα — Jaime Garcia Chaparro"
  description="Επαγγελματική εμπειρία και εκπαίδευση του Jaime Garcia Chaparro, Senior AI Engineer."
>
  <section class="mx-auto max-w-3xl px-4 py-4 sm:px-6 sm:py-8">
    <header class="mb-4 sm:mb-6">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">Καριέρα</h1>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-400">
        Από τις Διεθνείς Σχέσεις στην εφαρμοσμένη ΤΝ — ένα ταξίδι μέσα από την επιστήμη δεδομένων, το NLP και τη μηχανική μάθηση σε παραγωγή.
        Ένθερμος πολύγλωσσος με γνώση 8 γλωσσών: ισπανικά, αγγλικά, γαλλικά, ελληνικά, ρωσικά, λευκορωσικά, κινεζικά μανδαρίνα και τσακώνικα.
      </p>
      <div class="mt-6 flex justify-center">
        <a href="/cv-jaime-garcia-chaparro-2026.pdf" class="btn-primary" download>
          <Icon name="heroicons:arrow-down-tray-20-solid" class="h-5 w-5" />
          Λήψη βιογραφικού (PDF)
        </a>
      </div>
    </header>

    <!-- Επαγγελματική Εμπειρία -->
    <div class="mb-8 sm:mb-16">
      <h2 class="mb-6 flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-brand-700 dark:text-blue-400 sm:mb-8">
        <Icon name="heroicons:briefcase-20-solid" class="h-5 w-5" />
        Επαγγελματική Εμπειρία
      </h2>
      <ol class="ml-1">
        {
          experience.map((item, i) => (
            <TimelineItem {...item} lang="el" last={i === experience.length - 1} />
          ))
        }
      </ol>
    </div>

    <!-- Εκπαίδευση -->
    <div>
      <h2 class="mb-6 flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-brand-700 dark:text-blue-400 sm:mb-8">
        <Icon name="heroicons:academic-cap-20-solid" class="h-5 w-5" />
        Εκπαίδευση
      </h2>
      <ol class="ml-1">
        {
          education.map((item, i) => (
            <TimelineItem {...item} lang="el" last={i === education.length - 1} />
          ))
        }
      </ol>
    </div>

    <!-- Γλώσσες -->
    <div class="mt-8 sm:mt-16">
      <h2 class="mb-6 flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-brand-700 dark:text-blue-400">
        <Icon name="heroicons:language-solid" class="h-5 w-5" />
        Γλώσσες
      </h2>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-lg border border-slate-200 bg-slate-50 p-4 dark:border-white/10 dark:bg-white/5">
          <p class="flex items-center gap-2 font-semibold text-slate-900 dark:text-slate-50">
            <span class="text-lg">🇪🇸</span>
            Ισπανικά
          </p>
          <p class="text-sm text-slate-600 dark:text-slate-400">Μητρική γλώσσα</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-slate-50 p-4 dark:border-white/10 dark:bg-white/5">
          <p class="flex items-center gap-2 font-semibold text-slate-900 dark:text-slate-50">
            <span class="text-lg">🇬🇧</span>
            Αγγλικά
          </p>
          <p class="text-sm text-slate-600 dark:text-slate-400">C2 (Άριστη Γνώση)</p>
          <p class="mt-2 text-xs text-slate-500 dark:text-slate-500">Cambridge English Certificate, University of Cambridge</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-slate-50 p-4 dark:border-white/10 dark:bg-white/5">
          <p class="flex items-center gap-2 font-semibold text-slate-900 dark:text-slate-50">
            <span class="text-lg">🇬🇷</span>
            Ελληνικά
          </p>
          <p class="text-sm text-slate-600 dark:text-slate-400">B2 (Ανώτερο Μεσαίο)</p>
          <p class="mt-2 text-xs text-slate-500 dark:text-slate-500">Greek Language Center (B1)</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-slate-50 p-4 dark:border-white/10 dark:bg-white/5">
          <p class="flex items-center gap-2 font-semibold text-slate-900 dark:text-slate-50">
            <span class="text-lg">🇫🇷</span>
            Γαλλικά
          </p>
          <p class="text-sm text-slate-600 dark:text-slate-400">B2 (Ανώτερο Μεσαίο)</p>
          <p class="mt-2 text-xs text-slate-500 dark:text-slate-500">DELF B2, Alliance Française Málaga</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-slate-50 p-4 dark:border-white/10 dark:bg-white/5">
          <p class="flex items-center gap-2 font-semibold text-slate-900 dark:text-slate-50">
            <span class="text-lg">🇷🇺</span>
            Ρωσικά
          </p>
          <p class="text-sm text-slate-600 dark:text-slate-400">B1 (Μεσαίο)</p>
          <p class="mt-2 text-xs text-slate-500 dark:text-slate-500">Escuela Oficial de Idiomas de Málaga</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-slate-50 p-4 dark:border-white/10 dark:bg-white/5">
          <p class="flex items-center gap-2 font-semibold text-slate-900 dark:text-slate-50">
            <span class="text-lg">🇧🇾</span>
            Λευκορωσικά
          </p>
          <p class="text-sm text-slate-600 dark:text-slate-400">B1 (Μεσαίο)</p>
          <p class="mt-2 text-xs text-slate-500 dark:text-slate-500">International Summer School of Belarusian</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-slate-50 p-4 dark:border-white/10 dark:bg-white/5">
          <p class="flex items-center gap-2 font-semibold text-slate-900 dark:text-slate-50">
            <span class="text-lg">🇨🇳</span>
            Κινεζικά Μανδαρίνα
          </p>
          <p class="text-sm text-slate-600 dark:text-slate-400">B1 (Μεσαίο)</p>
          <p class="mt-2 text-xs text-slate-500 dark:text-slate-500">HSK4, Hanban Confucius Institute</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-slate-50 p-4 dark:border-white/10 dark:bg-white/5">
          <p class="flex items-center gap-2 font-semibold text-slate-900 dark:text-slate-50">
            <span class="text-lg">🇬🇷</span>
            Τσακώνικα
          </p>
          <p class="text-sm text-slate-600 dark:text-slate-400">A2 (Βασικό)</p>
          <p class="mt-2 text-xs text-slate-500 dark:text-slate-500">Αυτοδίδακτος</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
