---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout>
  <!-- Hero: Headline + Image aligned -->
  <section
    class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-4 sm:px-6 sm:py-8 lg:gap-12 lg:py-16"
  >
    <!-- Left: Eyebrow + Headline + CTAs -->
    <div class="flex flex-1 flex-col items-center justify-center text-center lg:max-w-2xl">
      <!-- Mobile Profile Image -->
      <div class="mb-4 lg:hidden">
        <div class="relative flex items-center justify-center">
          <div
            class="absolute -inset-4 rounded-full bg-gradient-to-tr from-brand-700 to-blue-500 opacity-20 blur-2xl"
            aria-hidden="true"
          >
          </div>
          <img
            src="/images/jaime-garcia-chaparro.jpg"
            alt="Jaime García Chaparro — Senior AI Engineer"
            width="200"
            height="200"
            class="relative h-48 w-48 rounded-full border-4 border-white object-cover shadow-2xl dark:border-white/10"
          />
        </div>
      </div>

      <!-- Eyebrow -->
      <p
        class="mb-2 inline-flex w-fit items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-1.5 text-xs font-semibold text-slate-600 dark:border-white/10 dark:bg-white/5 dark:text-slate-300"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"
          ></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
        </span>
        Senior AI Engineer &middot; Madrid
      </p>

      <!-- Headline — leads with the combo -->
      <h1
        class="text-balance text-4xl font-bold leading-tight tracking-tight text-slate-900 dark:text-slate-50 sm:text-5xl lg:text-6xl"
      >
        I build AI systems — and use them to help save a
        <span class="text-brand-700 dark:text-blue-400">critically endangered language</span>.
      </h1>

      <!-- CTAs -->
      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center">
        <a href="/cv-jaime-garcia-chaparro-2026.pdf" class="btn-primary" download>
          <Icon name="heroicons:arrow-down-tray-20-solid" class="h-5 w-5" />
          Download Resume (PDF)
        </a>
        <a href="/research" class="btn-secondary">
          Explore my research
          <Icon name="heroicons:arrow-right-20-solid" class="h-5 w-5" />
        </a>
      </div>
    </div>

    <!-- Right: Profile picture (hidden on mobile, shown on lg+) -->
    <div class="hidden min-h-[calc(100vh-4rem)] flex-shrink-0 lg:flex">
      <div class="relative flex items-center">
        <div
          class="absolute -inset-4 rounded-full bg-gradient-to-tr from-brand-700 to-blue-500 opacity-20 blur-2xl"
          aria-hidden="true"
        >
        </div>
        <img
          src="/images/jaime-garcia-chaparro.jpg"
          alt="Jaime García Chaparro — Senior AI Engineer"
          width="300"
          height="300"
          class="relative h-72 w-72 rounded-full border-4 border-white object-cover shadow-2xl dark:border-white/10"
        />
      </div>
    </div>
  </section>

  <!-- Presentation Section: Description below -->
  <section class="mx-auto max-w-5xl px-4 py-8 sm:px-6 sm:py-12">
    <div class="prose prose-slate max-w-none dark:prose-invert prose-headings:font-bold prose-headings:tracking-tight prose-p:text-slate-600 dark:prose-p:text-slate-400 prose-a:text-brand-700 dark:prose-a:text-blue-400 space-y-4 text-sm leading-relaxed">
      <p>
        Hi, I'm Jaime. Born in Málaga, based in Madrid, open to the World. I'm a
        Senior AI Engineer specializing in NLP and modern infrastructure — and I build
        digital tools to preserve <strong class="font-semibold text-slate-800 dark:text-slate-200">Tsakonian</strong>,
        a Doric Greek dialect spoken by only a few hundred people.
      </p>

      <p>
        Cross-disciplinary curiosity, continuous innovation, and new challenges are constants for me.
      </p>

      <p>
        As an AI engineer with over 3 years of professional experience and 8 years developing personal projects, I work designing, implementing, and scaling AI-powered digital solutions, such as agent systems with LangChain, LangGraph, and LangSmith, RAGs, and LLMs, supported by solid practical experience with Python, BigQuery, Databricks, GCP, and Azure.
      </p>

      <p>
        Seeking to broaden my horizons, I am independently researching NLP for the digital preservation of the critically endangered Tsakonian language, using open-source models and fine-tuning techniques for LLMs and OCRs. I also taught Neural Networks at Alfonso X el Sabio University during the 2024-2025 academic year.
      </p>

      <p>
        I am a passionate polyglot and amateur linguist with knowledge of 8 languages: Spanish, English, French, Greek, Russian, Belarusian, Mandarin Chinese, and Tsakonian. Linked to my background in Business Administration and International Relations, economics, history, and geopolitics are topics of particular interest to me.
      </p>
    </div>
  </section>
</BaseLayout>
